<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="10dp"
    android:layout_marginBottom="4dp"
    android:background="@drawable/row_highlight"
    android:clickable="true"
    android:focusable="true">

    <TextView
        android:id="@+id/Rank"
        android:layout_width="wrap_content"
        android:minWidth="28dp"
        android:layout_height="wrap_content"
        android:text="position"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#386B01"
        android:gravity="center"
        android:importantForAccessibility="yes"
        tools:ignore="HardcodedText" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/DonorPic"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="4dp"
        android:layout_marginStart="8dp"
        android:src="@drawable/ic_launcher_foreground"
        android:scaleType="centerCrop"
        android:contentDescription="@string/donation_icon_description"
        app:shapeAppearanceOverlay="@style/CircleImageStyle"
        app:strokeColor="#386B01"
        app:strokeWidth="1dp" />

    <TextView
        android:id="@+id/DonorName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:text="--name--"
        android:textSize="14sp"
        android:textColor="#163300"
        android:textStyle="bold"
        tools:ignore="HardcodedText" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/DonorCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="count"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#163300"
            android:gravity="end"
            tools:ignore="HardcodedText" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/items_donated"
            android:textSize="12sp"
            android:textColor="#595959"
            android:gravity="end" />

    </LinearLayout>

</LinearLayout>