<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#D1FFBD"
    android:padding="24dp">

    <ImageView
        android:id="@+id/DonateIcon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/donate_ic"
        android:contentDescription="@string/donation_icon_description"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/PopupTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/PopupTitle"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#163300"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/DonateIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/PopupSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/PopupSubtitle"
        android:textSize="13sp"
        android:textColor="#555555"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        app:layout_constraintTop_toBottomOf="@id/PopupTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnClosePopup"
        android:layout_width="320dp"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:text="@string/popupclosebtn"
        android:textColor="#163300"
        android:textSize="15sp"
        android:textStyle="bold"
        android:backgroundTint="#9FE870"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/PopupSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>